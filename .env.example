# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase: Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Web Push for money-moment alerts (optional). Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here; set the private key as the notify edge fn's secret.
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
